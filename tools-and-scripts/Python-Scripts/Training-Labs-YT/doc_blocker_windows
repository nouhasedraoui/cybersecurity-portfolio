import os
import sys
import time
import logging
from collections import defaultdict
from scapy.all import sniff, IP

logging.basicConfig(filename='dos_defense_win.log', level=logging.INFO, format='%(asctime)s - %(message)s')

THRESHOLD = 40

def packet_callback(packet):
    if IP in packet:
        src_ip = packet[IP].src
        packet_count[src_ip] += 1
        current_time = time.time()
        if current_time - start_time[0] >= 1:
            for ip, count in packet_count.items():
                if count > THRESHOLD and ip not in blocked_ips:
                    logging.warning(f"BLOCKING IP: {ip} - Rate: {count} p/s")
                    # Windows Firewall Command
                    cmd = f'netsh advfirewall firewall add rule name="Block_{ip}" dir=in action=block remoteip={ip}'
                    os.system(cmd)
                    blocked_ips.add(ip)
            packet_count.clear()
            start_time[0] = current_time

if __name__ == "__main__":
    # Ensure admin privileges
    packet_count = defaultdict(int)
    start_time = [time.time()]
    blocked_ips = set()
    print("Monitoring Windows Traffic...")
    sniff(filter="ip", prn=packet_callback)
